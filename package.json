{
  "name": "mcpbolt",
  "version": "0.3.1",
  "description": "Wire MCP servers into any AI coding tool from one paste",
  "type": "module",
  "bin": {
    "mcpbolt": "dist/cli/index.js"
  },
  "files": [
    "dist/cli/index.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun src/cli/index.ts",
    "build": "npx esbuild src/cli/index.ts --outdir=dist/cli --platform=node --bundle --minify --format=esm",
    "build:bun": "bun build src/cli/index.ts --outdir dist/cli --target node --minify",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "installer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vishmathpati/mcpwire.git"
  }
}
